# ─────────────────────────────────────────────────────────────────────────────
# Local developer overrides — NEVER commit the real file.
#
# Usage:
#   1. cp application-local.properties.example application-local.properties
#   2. Fill in your local MySQL credentials below.
#   3. Start the app with --spring.profiles.active=local
#      or set SPRING_PROFILES_ACTIVE=local in your IDE run configuration.
#
# application-local.properties is listed in .gitignore and will not be staged.
# ─────────────────────────────────────────────────────────────────────────────

spring.datasource.url=jdbc:mysql://localhost:3306/svirerp?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=YOUR_DB_USER
spring.datasource.password=YOUR_DB_PASSWORD

# Uncomment if your local svirerp database was previously migrated by a different branch
# that added migrations not present in the branch you're currently on — Flyway will
# otherwise fail with "Detected applied migration not resolved locally" for those versions.
# spring.flyway.ignore-migration-patterns=*:missing

# Google OAuth2 client for LOCAL DEVELOPMENT — create a separate dev-only
# OAuth Client in Google Cloud Console (redirect URI
# http://localhost:8080/login/oauth2/code/google). Do not reuse the
# production client's secret here. No longer a property — log in as the
# local admin below and set these on the Settings page instead.

# Break-glass local admin login — leave blank to disable. Generate the hash
# once via a throwaway `new BCryptPasswordEncoder().encode("your-password")`
# call; never commit a real hash or plaintext password here.

app.auth.admin.username = ADMIN_USER_NAME
app.auth.admin.password-hash = ADMIN_PASSWORD_HASH

# Encrypts SECRET-type rows in the app_setting table (e.g. the Google OAuth
# client secret above). Salt must be hex-encoded. Losing either value
# permanently strands any already-encrypted settings — see
# application.properties for details.
app.settings.encryption-key = YOUR_LOCAL_DEV_ENCRYPTION_KEY
app.settings.encryption-salt = deadbeef00112233
